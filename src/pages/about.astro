---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import myLocalImage from '/public/headshot.jpeg';

const skills = [
  { category: "Languages", items: ["Swift", "Python", "Java", "SQL", "TypeScript", "HTML", "C", "JSON", "YANG"] },
  { category: "Skills", items: ["AI", "Scrum", "Ansible", "Networking", "Requirements Elicitation", "NETCONF/RESTCONF", "UI/UX Design", "RESTful APIs", "Agile"] },
  { category: "Tools", items: ["Git", "Jira", "Cursor", "Claude Code", "Docker", "AWS", "VS Code", "Intellij", "Webstorm", "Xcode", "PostMan"] },
  { category: "Frameworks", items: ["Cucumber", "SpringBoot", "Astro", "Docusaurus"] },
];

const education = [
  {
    degree: "Bachelor of Software Engineering with Honours",
    institution: "University of Canterbury",
    period: "2023 - Present",
    description: "Currently in my fourth year currently completing my Honours project and taking courses in Machine Learning, Software Requirements and Architecture and Advanced Software Engineering."
  },
  {
    degree: "High School",
    institution: "Takapuna Grammar",
    period: "2018 - 2022",
    description: "I studied here for the entirety of my high school education. In my final year I was elected as a Prefect. I was also a member of the 1st XI hockey team."
  }
];

const experiences = [
  {
    position: "Software Engineering Intern",
    company: "Allied Telesis Labs",
    period: "Summer 2025/2026",
    description: "During this internships I worked on Testing and Development of NETCONF, RESTONF and Ansible protocols for Allied Telesis network devices. I then developed an graphical interface and backend that used these protocols to allow for easy, remote setup, configuration and management of spine-leaf data center networks"
  },
  {
    position: "Software Engineering Intern",
    company: "Raytio",
    period: "Summer 2024/2025 & Part Time July 2023 - Present",
    description: "During this internship I developed a companion iOS application for the Raytio web client called Global-IDV. I also worked on creating a usage and subscription billing system for Raytio, helping to prepare them for launch. I have worked for Raytio in the holidays and spare time since July 2023. Over the 24/25 summer I completed a 400+ hour internship here and have completed 800+ hours here total over my tenure."
  },
  {
    position: "Building Labourer",
    company: "Self-Employed",
    period: "Summer 2023/2024",
    description: "During this time I completed various building labouring jobs for multiple people in the local community 2-4 days per week."
  },
  {
    position: "Food Service Worker",
    company: "McDonald's",
    period: "Aug 2021 - Feb 2023",
    description: "I worked at McDonald's during my time at high school for 16-20 hours per week, where I learned valuable skills in customer service, teamwork, and time management."
  },
  {
    position: "Food Service Worker",
    company: "The Taste Devonport",
    period: "May 2021 - Aug 2021",
    description: "I worked at The Taste (Thai Restaurant) during high school for ~10 hours per week, where I gained knowledge in cooking various curries and improved on my time management skills."
  }
];
---

<Layout
  title="About Me | Samuel Beattie"
  description="Learn more about Samuel Beattie - a software engineering student passionate about web development and innovative solutions."
>
  <section class="py-16 md:py-24 animate-fade-in">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-8 text-neutral-900 dark:text-white">
          About Me
        </h1>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="md:col-span-1">
            <div class="sticky top-24">
              <Image src={myLocalImage} 
              alt="Samuel Beattie"
              class="w-full aspect-square object-cover rounded-xl mb-4 shadow-md"
              />
            </div>
          </div>
          
          <div class="md:col-span-2">
            <div class="prose prose-lg dark:prose-invert">
              <p>
                Hello! I'm a passionate final-year software engineering student looking to make a positive impact in the tech industry. 
              </p>
              
              <p>
                When I'm not coding, you can find me outdoors, spending time with friends and family, or learning about something new. I'm always looking for new challenges and opportunities to grow as an engineer and as a person.
              </p>

              <p>
                I am motivated by complex challenges that push me to work hard, learn and think critically. I am particularly interested in working in a modern environment that embraces change and new ideas,  while providing opportunities for me to grow in both technical and professional areas of my career and as a person. I am passionate about working with the latest technologies and applying my skills to solve real-world problems and create innovative solutions. I am excited to see what the future holds for me and the tech industry in the AI age!
              </p>
              
              <p>
                I'm currently seeking graduate opportunities where I can apply my skills and learn from experienced professionals. Feel free to reach out if you think we could work together!
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Skills Section -->
  <section class="py-12 bg-neutral-50 dark:bg-neutral-800/50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-8 text-neutral-900 dark:text-white">
          Skills & Technologies
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {skills.map(skillGroup => (
            <div class="bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-xl p-6 shadow-sm">
              <h3 class="text-xl font-semibold mb-4 text-neutral-900 dark:text-white">
                {skillGroup.category}
              </h3>
              
              <div class="flex flex-wrap gap-2">
                {skillGroup.items.map(skill => (
                  <span class="px-3 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-full text-sm">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  
  <!-- Education Section -->
  <section class="py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-8 text-neutral-900 dark:text-white">
          Education
        </h2>
        
        {education.map(edu => (
          <div class="mb-8 bg-white dark:bg-neutral-800 rounded-xl border border-neutral-200 dark:border-neutral-700 p-6 shadow-sm">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
              <h3 class="text-xl font-semibold text-neutral-900 dark:text-white">
                {edu.degree}
              </h3>
              
              <span class="text-primary-600 dark:text-primary-400 font-medium">
                {edu.period}
              </span>
            </div>
            
            <p class="text-neutral-700 dark:text-neutral-300 mb-2">
              {edu.institution}
            </p>
            
            <p class="text-neutral-600 dark:text-neutral-400">
              {edu.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Experience Section -->
  {experiences.length > 0 && (
    <section class="py-12 bg-neutral-50 dark:bg-neutral-800/50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-bold mb-8 text-neutral-900 dark:text-white">
            Experience
          </h2>
          
          {experiences.map(exp => (
            <div class="mb-8 bg-white dark:bg-neutral-800 rounded-xl border border-neutral-200 dark:border-neutral-700 p-6 shadow-sm">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
                <h3 class="text-xl font-semibold text-neutral-900 dark:text-white">
                  {exp.position}
                </h3>
                
                <span class="text-primary-600 dark:text-primary-400 font-medium">
                  {exp.period}
                </span>
              </div>
              
              <p class="text-neutral-700 dark:text-neutral-300 mb-2">
                {exp.company}
              </p>
              
              <p class="text-neutral-600 dark:text-neutral-400">
                {exp.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .prose {
    max-width: 100%;
  }
  
  .prose p {
    margin-bottom: 1.5em;
  }
</style>